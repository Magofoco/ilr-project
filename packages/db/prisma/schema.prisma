// Prisma schema for ILR Tracker
// Uses Supabase Postgres with connection pooling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ============================================
// FORUM SOURCES
// ============================================

model SourceForum {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "immigrationboards", "ukvisa-reddit"
  displayName String   @map("display_name")
  baseUrl     String   @map("base_url")
  type        String   // "playwright" | "fetch" - determines scraping strategy
  config      Json     @default("{}") // source-specific config (selectors, pagination, etc.)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  threads    Thread[]
  scrapeRuns ScrapeRun[]

  @@map("source_forums")
}

// ============================================
// THREADS & POSTS
// ============================================

model Thread {
  id              String   @id @default(cuid())
  sourceId        String   @map("source_id")
  externalId      String   @map("external_id") // Forum's own thread ID
  url             String
  title           String
  authorName      String?  @map("author_name")
  postedAt        DateTime? @map("posted_at")
  lastScrapedAt   DateTime? @map("last_scraped_at")
  lastScrapedPage Int?     @map("last_scraped_page") // For resume capability
  totalPages      Int?     @map("total_pages") // Total pages discovered
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  source SourceForum @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  posts  Post[]

  @@unique([sourceId, externalId])
  @@index([sourceId])
  @@index([postedAt])
  @@map("threads")
}

model Post {
  id           String   @id @default(cuid())
  threadId     String   @map("thread_id")
  externalId        String   @map("external_id") // Forum's own post ID (e.g., "p12345")
  authorName        String?  @map("author_name")
  authorNationality String?  @map("author_nationality") // From forum profile flag image
  content           String   // Raw content (we store relevant text, not entire HTML)
  contentHash  String   @map("content_hash") // For dedup/change detection
  postedAt     DateTime? @map("posted_at")
  scrapedAt    DateTime @default(now()) @map("scraped_at")
  pageNumber   Int?     @map("page_number") // Which page of the thread this post was on
  createdAt    DateTime @default(now()) @map("created_at")

  thread        Thread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  extractedCase ExtractedCase?

  @@unique([threadId, externalId])
  @@index([threadId])
  @@index([contentHash])
  @@index([pageNumber])
  @@map("posts")
}

// ============================================
// EXTRACTED CASE DATA
// ============================================

model ExtractedCase {
  id                String   @id @default(cuid())
  postId            String   @unique @map("post_id")

  // ============ ROUTE / TYPE ============
  applicationType   String?  @map("application_type") // e.g., "ILR", "FLR(M)", "Naturalization"
  applicationRoute  String?  @map("application_route") // e.g., "SET(O)", "10-year", "BN(O)", "Skilled Worker"
  // Service tier — first-class so we can stratify or filter the cohort.
  // "standard" | "priority" | "super_priority". NULL = unknown.
  serviceTier       String?  @map("service_tier")

  // ============ TIMELINE (snapshot view; CaseEvent has the full stream) ============
  applicationDate   DateTime? @map("application_date")
  biometricsDate    DateTime? @map("biometrics_date")
  // First "more documents requested" event date (if any). Null if none.
  docsRequestedDate DateTime? @map("docs_requested_date")
  // Date the applicant submitted the additional docs / followed up.
  docsSubmittedDate DateTime? @map("docs_submitted_date")
  decisionDate      DateTime? @map("decision_date")
  // Computed: decisionDate - applicationDate (in days). Null while still pending.
  waitingDays       Int?     @map("waiting_days")

  // ============ LOCATION ============
  // UKVCAS biometrics location (e.g., "Wandsworth", "Sheffield", "Nottingham").
  // This is what the forum actually reports; NOT the Home Office decision center.
  biometricsLocation String?  @map("biometrics_location")
  // Home Office decision center (e.g., "Sheffield", "Liverpool", "Croydon").
  // Rarely populated by the forum — present for forward compatibility.
  decisionCenter     String?  @map("decision_center")

  // ============ APPLICANT ============
  // Free-form nationality string from the forum profile flag (e.g., "India", "Hong Kong (...)").
  // This preserves the original signal.
  applicantNationality     String?  @map("applicant_nationality")
  // Normalized ISO-3166 alpha-2 code (e.g., "IN", "HK"). Backfilled from the lookup table.
  applicantNationalityCode String?  @map("applicant_nationality_code")

  // ============ OUTCOME ============
  outcome   String?  // "approved" | "rejected" | "pending" | "unknown"
  // Denormalized: true if outcome is "pending" OR (decisionDate is null AND applicationDate is set).
  // Cached so survival queries can index instead of recomputing per row.
  isPending Boolean  @default(false) @map("is_pending")

  // ============ EXTRACTION METADATA ============
  confidence       Float    @default(0) // 0-1 score
  extractionNotes  String?  @map("extraction_notes")
  extractedAt      DateTime @default(now()) @map("extracted_at")
  extractorVersion String   @default("1.0") @map("extractor_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post   Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  events CaseEvent[]

  @@index([applicationType])
  @@index([applicationRoute])
  @@index([applicationDate])
  @@index([decisionDate])
  @@index([outcome])
  @@index([confidence])
  @@index([serviceTier])
  @@index([biometricsLocation])
  @@index([applicantNationalityCode])
  @@index([isPending])
  @@map("extracted_cases")
}

// ============================================
// CASE EVENTS (the milestone stream)
// ============================================
// One row per extracted milestone. The same post can produce multiple events.
// Re-extraction wipes existing rows for the case and recreates them, so the
// event set is always consistent with the latest extractor version.
model CaseEvent {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  // "applied" | "biometrics" | "acknowledgement"
  // | "docs_requested" | "docs_submitted" | "decision"
  type       String
  eventDate  DateTime @map("event_date")
  // Confidence in this specific event extraction (0..1).
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now()) @map("created_at")

  case ExtractedCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Same case + type + date should not appear twice.
  // This makes upserts during re-extraction safe.
  @@unique([caseId, type, eventDate])
  @@index([caseId])
  @@index([type])
  @@index([eventDate])
  @@map("case_events")
}

// ============================================
// SCRAPE RUNS (Logging)
// ============================================

model ScrapeRun {
  id            String   @id @default(cuid())
  sourceId      String   @map("source_id")
  status        String   // "running", "completed", "failed"
  startedAt     DateTime @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  
  // Stats
  threadsFound    Int @default(0) @map("threads_found")
  threadsScraped  Int @default(0) @map("threads_scraped")
  postsFound      Int @default(0) @map("posts_found")
  postsScraped    Int @default(0) @map("posts_scraped")
  casesExtracted  Int @default(0) @map("cases_extracted")
  
  // Error tracking
  errorMessage  String? @map("error_message")
  errorDetails  Json?   @map("error_details")
  
  // Config used for this run
  runConfig     Json    @default("{}") @map("run_config")

  source SourceForum @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([startedAt])
  @@index([status])
  @@map("scrape_runs")
}

// ============================================
// USER ROLES (for admin access)
// ============================================
// Note: Supabase Auth handles user authentication.
// This table maps Supabase user IDs to roles.

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id") // Supabase Auth user ID
  role      String   @default("user") // "user" | "admin"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

// ============================================
// PRODUCTS / PURCHASES / ENTITLEMENTS
// ============================================
// Pattern: one Purchase represents a money flow (Stripe Checkout session).
// A Purchase grants one or more Entitlements (rows in the entitlements table),
// each of which represents access to a specific Product. This separates
// "what was paid" from "what the user can access" — bundles, refunds, and
// manual/promo grants all model cleanly without special cases.
//
// Idempotency: StripeEvent.stripeEventId is unique so webhook retries can't
// double-grant. Always upsert by stripeEventId in the webhook handler.

enum Product {
  ILR_TRACKER // £29 one-off — ILR waiting-time estimator
  LIFE_IN_UK  // Life in the UK test preparation (future)
  // Add new products here. Bundles are represented as multiple Entitlements
  // under a single Purchase, NOT as a separate product value.
}

model Purchase {
  id                    String   @id @default(cuid())
  // Supabase Auth user ID (matches UserRole.userId convention; no FK).
  userId                String   @map("user_id")

  // Stripe linkage
  stripeCustomerId      String?  @map("stripe_customer_id")
  stripeCheckoutId      String?  @unique @map("stripe_checkout_id")
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  stripeSubscriptionId  String?  @map("stripe_subscription_id") // For recurring (e.g. £4.99/mo add-on)

  // Money
  amountPaidCents       Int      @map("amount_paid_cents") // 2900 = £29.00
  currency              String   @default("GBP")           // ISO-4217

  // Lifecycle
  // "paid" | "refunded" | "partially_refunded" | "disputed" | "failed" | "pending"
  status                String   @default("paid")
  source                String   @default("stripe") // "stripe" | "promo" | "manual"
  refundedAt            DateTime? @map("refunded_at")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt        @map("updated_at")

  entitlements          Entitlement[]

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("purchases")
}

model Entitlement {
  id          String   @id @default(cuid())
  // Supabase Auth user ID. Duplicated from Purchase.userId for fast access
  // checks without a JOIN (the hot path: "does this user have access to X?").
  userId      String   @map("user_id")
  product     Product

  // null = manual grant or promo (no money flow). Otherwise the parent Purchase.
  purchaseId  String?  @map("purchase_id")

  // Lifecycle
  // "active" | "expired" | "revoked" | "refunded"
  status      String   @default("active")
  startedAt   DateTime @default(now()) @map("started_at")
  expiresAt   DateTime? @map("expires_at") // null = lifetime (e.g. "until decision" until we mark it)
  revokedAt   DateTime? @map("revoked_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  purchase    Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  // Hot-path query: WHERE userId = ? AND product = ? AND status = 'active'
  @@index([userId, product, status])
  @@index([purchaseId])
  @@map("entitlements")
}

// ============================================
// STRIPE WEBHOOK AUDIT LOG
// ============================================
// Persisted log of every Stripe webhook we receive. The unique constraint
// on stripeEventId enforces idempotency — Stripe retries the same event on
// network failures, deploys, etc., and we must not double-process.
//
// processedAt = null and error = null means "not yet processed".
// processedAt set and error = null means "processed successfully".
// error set means we tried and failed; safe to retry from the admin UI later.

model StripeEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique @map("stripe_event_id")
  type          String    // e.g. "checkout.session.completed", "charge.refunded"
  payload       Json
  processedAt   DateTime? @map("processed_at")
  error         String?

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([type])
  @@index([processedAt])
  @@map("stripe_events")
}
